# ===========================================
# InstiVault — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- ADI Foundation Chain ---
ADI_RPC_URL=http://localhost:8545
ADI_PRIVATE_KEY=
ADI_CHAIN_ID=

# ADI Deployed Addresses (filled after running Deploy.s.sol)
ADI_ACCESS_CONTROL_ADDRESS=
ADI_TOKEN_FACTORY_ADDRESS=
ADI_VAULT_MANAGER_ADDRESS=
ADI_INSTITUTION_REGISTRY_ADDRESS=

# --- Hedera Testnet ---
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
HEDERA_NETWORK=testnet

# Hedera Deployed Addresses (filled after running deploy.ts)
HEDERA_COUPON_SCHEDULER_ADDRESS=
HEDERA_YIELD_DISTRIBUTOR_ADDRESS=

# --- Canton Network ---
CANTON_LEDGER_HOST=
CANTON_LEDGER_PORT=6865
CANTON_JSON_API_PORT=7575
CANTON_LEDGER_ID=instivault
CANTON_PACKAGE_ID=instivault
CANTON_PARTY_ADMIN=
CANTON_PARTY_ISSUER=
CANTON_PARTY_INVESTOR=
CANTON_PARTY_AUDITOR=

# --- 0G Labs ---
ZG_COMPUTE_ENDPOINT=
ZG_API_KEY=

# --- Backend ---
PORT=3001

# --- Frontend ---
NEXT_PUBLIC_ADI_RPC_URL=
NEXT_PUBLIC_HEDERA_NETWORK=testnet
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
