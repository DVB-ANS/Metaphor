# ===========================================
# Metaphor — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- ADI Foundation Chain ---
ADI_RPC_URL=https://rpc.ab.testnet.adifoundation.ai/
ADI_PRIVATE_KEY=
ADI_CHAIN_ID=99999

# ADI Deployed Addresses (filled after running Deploy.s.sol)
ADI_ACCESS_CONTROL_ADDRESS=
ADI_TOKEN_FACTORY_ADDRESS=
ADI_VAULT_MANAGER_ADDRESS=
ADI_INSTITUTION_REGISTRY_ADDRESS=

# --- Hedera Testnet ---
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
HEDERA_NETWORK=testnet
HEDERA_RPC_URL=https://testnet.hashio.io/api
HEDERA_PRIVATE_KEY=

# Hedera Deployed Addresses (filled after running deploy.ts)
HEDERA_COUPON_SCHEDULER_ADDRESS=
HEDERA_YIELD_DISTRIBUTOR_ADDRESS=

# --- Canton Network (LocalNet sandbox) ---
CANTON_LEDGER_HOST=localhost
CANTON_LEDGER_PORT=6865
CANTON_JSON_API_PORT=7575
CANTON_LEDGER_ID=sandbox
CANTON_PACKAGE_ID=
CANTON_PARTY_ADMIN=
CANTON_PARTY_ISSUER=
CANTON_PARTY_INVESTOR=
CANTON_PARTY_AUDITOR=

# --- 0G Labs ---
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_PRIVATE_KEY=
ZG_USE_MOCK=true
ZG_COMPUTE_ENDPOINT=
ZG_API_KEY=

# --- Backend ---
PORT=3001
JWT_SECRET=
DEV_MODE=true

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ADI_RPC_URL=https://rpc.ab.testnet.adifoundation.ai
NEXT_PUBLIC_HEDERA_NETWORK=testnet
# Get your project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
